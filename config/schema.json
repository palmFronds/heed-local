{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["platformId", "selectors", "completionSelector", "partnerOrigin"],
  "additionalProperties": false,
  "properties": {
    "platformId": { "type": "string" },
    "completionSelector": { "type": "string" },
    "activeScreens": { "type": "array" },
    "partnerOrigin": { "type": "string" },
    "weightPushUrl": { "type": "string" },
    "responses": { "type": "object" },
    "selectors": {
      "type": "object",
      "required": [
        "amountInput",
        "feeRow",
        "minReceivedRow",
        "proceedCta",
        "confirmCta",
        "backBtn",
        "flowComplete"
      ],
      "additionalProperties": false,
      "properties": {
        "amountInput": { "type": "string" },
        "feeRow": { "type": "string" },
        "minReceivedRow": { "type": "string" },
        "proceedCta": { "type": "string" },
        "confirmCta": { "type": "string" },
        "backBtn": { "type": "string" },
        "flowComplete": { "type": "string" }
      }
    },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "touchHesitation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "thresholdMs": { "type": "number" }
          }
        },
        "scrollReversal": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "depthThresholdPct": { "type": "number" },
            "minReversalDeltaPx": { "type": "number" }
          }
        }
      }
    },
    "inference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "confidenceThreshold": { "type": "number" },
        "weights": { "type": "object" }
      }
    }
  }
}
